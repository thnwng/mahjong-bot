# Complete env-var catalog for mahjong-web. Copy to .env.local for local dev.
# (Workspace hard rule: nothing here may live in global Windows env vars.)

# URL of the deployed Supabase `track` Edge Function. Empty = the tracker runs
# in local-only mode (no shared groups). In CI this comes from the repo
# variable TRACK_URL (Settings -> Secrets and variables -> Actions -> Variables).
NEXT_PUBLIC_TRACK_URL=

# Mini App deep link used for share buttons, e.g. https://t.me/<bot>/<shortname>.
# In CI this comes from the repo variable BOT_APP_LINK.
NEXT_PUBLIC_BOT_APP_LINK=

# Base path for GitHub Pages project sites (/<repo>). Set only in CI; leave
# empty for local dev.
NEXT_PUBLIC_BASE_PATH=

# NOT here (server-side secrets, set as Supabase Edge Function secrets):
#   BOT_TOKEN        - the Telegram bot token (validates initData + sends messages)
#   WEBHOOK_SECRET   - random string echoed by Telegram in the webhook header
# And one GitHub repo secret for CI function deploys:
#   SUPABASE_ACCESS_TOKEN - from supabase.com account settings -> Access Tokens
