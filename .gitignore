# Ignore ALL env files (not just *.local): a committed .env / .env.production is
# auto-loaded by `next build`, and one containing NEXT_PUBLIC_OFFLINE=true would
# silently route real-money writes to the localStorage dev backend in production.
.env
.env.*
!.env.example

